---
import '../styles/studio.css';
interface Props { title: string; description?: string; active?: string; }
const { title, description = '키워드부터 채널별 글·이미지·발행까지 — 수익형 콘텐츠 스튜디오', active = '' } = Astro.props;
const NAV = [
	{ key: 'pipeline', label: '💸 파이프라인', href: '/pipeline' },
	{ key: 'start', label: '대시보드', href: '/start' },
	{ key: 'keywords', label: '키워드', href: '/keywords' },
	{ key: 'approval', label: '승인', href: '/approval' },
	{ key: 'glossary', label: '가이드', href: '/glossary' },
	{ key: 'launch', label: '런처', href: '/tools/launch' },
];
---

<!doctype html>
<html lang="ko">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="robots" content="noindex" />
		<title>{title} · 수익 스튜디오</title>
		<meta name="description" content={description} />
		<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='90'%3E%F0%9F%92%B0%3C/text%3E%3C/svg%3E" />
	</head>
	<body>
		<header class="topnav">
			<div class="inner">
				<a class="brand" href="/"><span class="dot"></span>수익 스튜디오</a>
				<button class="navtoggle" id="navtoggle" aria-label="메뉴">☰</button>
				<nav class="navlinks" id="navlinks">
					{NAV.map((n) => <a href={n.href} class={active === n.key ? 'active' : ''}>{n.label}</a>)}
				</nav>
			</div>
		</header>
		<main>
			<div class="container">
				<slot />
			</div>
		</main>
		<script>
			const t = document.getElementById('navtoggle');
			const n = document.getElementById('navlinks');
			t?.addEventListener('click', () => n?.classList.toggle('open'));
		</script>
	</body>
</html>
