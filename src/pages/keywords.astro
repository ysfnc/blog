---
import StudioLayout from '../layouts/StudioLayout.astro';
import { TIER_LEGEND, GOLDEN, EVERGREEN, CALENDAR, allKeywords } from '../data/keywords';
const all = allKeywords();
---

<StudioLayout title="키워드" active="keywords">
	<h1 class="page-h">🔑 고CPC 키워드 시드</h1>
	<p class="page-sub">자료 기반 황금키워드 30 + 2026 12개월 시즌 캘린더 + 365일 상시 키워드. ⚠️ 정확한 CPC 금액은 원문에 없어 <b>등급(💰)</b>으로만 표시합니다.</p>

	<div class="card">
		<div style="display:flex;gap:.6rem;flex-wrap:wrap">
			{TIER_LEGEND.map((t) => (
				<div class="chip"><span class="tier">{t.tier}</span> <b>{t.label}</b> <span class="muted" style="font-size:.76rem">{t.cpc}</span></div>
			))}
		</div>
	</div>

	<div class="card" style="margin-top:1rem">
		<div class="field" style="margin-bottom:.6rem"><input type="text" id="kw-search" placeholder="키워드 검색 (예: 보험, 대출, 연말정산)" /></div>
		<div class="tabs" id="kw-tabs">
			<button class="tab active" data-f="all">전체 <span class="muted">{all.length}</span></button>
			<button class="tab" data-f="gold">💰💰💰 황금</button>
			<button class="tab" data-f="season">🔥 시즌</button>
			<button class="tab" data-f="evergreen">📅 상시</button>
			<button class="tab" data-f="month">이번 달</button>
		</div>
		<div id="kw-list" class="grid grid-2" style="gap:.5rem">
			{all.map((k) => (
				<div class="card kw-item" data-kw={k.kw} data-tiers={k.tiers.join('')} data-source={k.source} style="padding:.6rem .8rem;box-shadow:none;display:flex;justify-content:space-between;align-items:center;gap:.5rem">
					<div>
						<span class="tier">{k.tiers.join('')}</span> <b>{k.kw}</b>
						<div class="muted" style="font-size:.74rem">{k.source}{k.note ? ' · ' + k.note : ''}</div>
					</div>
					<a class="btn btn-soft btn-sm" href={`/tools/generate?topic=${encodeURIComponent(k.kw)}`}>글쓰기</a>
				</div>
			))}
		</div>
		<p id="kw-empty" class="muted hidden" style="text-align:center;padding:1rem">검색 결과가 없어요.</p>
	</div>

	<h3 class="section-h">📆 월별 시즌 캘린더 (선점 발행용)</h3>
	<div class="grid grid-2">
		{CALENDAR.map((m) => (
			<details class="card" style="padding:.8rem 1rem">
				<summary style="cursor:pointer;font-weight:700"><b>{m.month}월</b> · {m.theme}</summary>
				<p class="hint" style="margin:.4rem 0">💡 {m.strategy}</p>
				{m.keywords.map((k) => (
					<div style="font-size:.85rem;padding:.15rem 0"><span class="tier">{k.tiers.join('')}</span> {k.kw}</div>
				))}
			</details>
		))}
	</div>

	<h3 class="section-h">🏅 고단가 황금키워드 30 (행동유도형)</h3>
	<div class="grid grid-3">
		{GOLDEN.map((g) => (
			<div class="card" style="padding:.8rem 1rem">
				<b>{g.category}</b>
				{g.items.map((it) => <div style="font-size:.84rem;padding:.12rem 0">· {it}</div>)}
			</div>
		))}
	</div>
</StudioLayout>

<script>
	const search = document.getElementById('kw-search') as HTMLInputElement;
	const items = Array.from(document.querySelectorAll<HTMLElement>('.kw-item'));
	const tabs = document.querySelectorAll<HTMLElement>('#kw-tabs .tab');
	let filter = 'all';
	const month = new Date().getMonth() + 1;
	function apply() {
		const q = search.value.trim();
		let shown = 0;
		items.forEach((el) => {
			const kw = el.dataset.kw || '', tiers = el.dataset.tiers || '', src = el.dataset.source || '';
			let ok = !q || kw.includes(q);
			if (ok && filter === 'gold') ok = tiers.includes('💰💰💰');
			if (ok && filter === 'season') ok = tiers.includes('🔥');
			if (ok && filter === 'evergreen') ok = src.startsWith('상시');
			if (ok && filter === 'month') ok = src === `${month}월`;
			el.classList.toggle('hidden', !ok);
			if (ok) shown++;
		});
		document.getElementById('kw-empty')!.classList.toggle('hidden', shown > 0);
	}
	search.addEventListener('input', apply);
	tabs.forEach((t) => t.addEventListener('click', () => { tabs.forEach((x) => x.classList.remove('active')); t.classList.add('active'); filter = t.dataset.f!; apply(); }));
</script>
