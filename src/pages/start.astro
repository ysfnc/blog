---
import StudioLayout from '../layouts/StudioLayout.astro';
---

<StudioLayout title="대시보드" active="start">
	<div id="hero"></div>

	<div class="grid grid-3" id="pub-stats" style="margin-top:1rem"></div>

	<div class="card" style="margin-top:1rem">
		<div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.5rem">
			<h3 class="section-h" style="margin:0">📅 이번 달 시즌 키워드 <span id="month-tag" class="muted" style="font-weight:400;font-size:.85rem"></span></h3>
			<a class="btn btn-soft btn-sm" href="/keywords">전체 키워드 →</a>
		</div>
		<p class="hint" id="month-strategy" style="margin:.3rem 0 .7rem"></p>
		<div id="season-kws" class="grid" style="gap:.5rem"></div>
	</div>

	<div class="card" style="margin-top:1rem">
		<div style="display:flex;justify-content:space-between;align-items:center;gap:.6rem;flex-wrap:wrap">
			<div><h3 class="section-h" style="margin:0">🚀 오늘의 발행 루프 <b id="loop-pct" class="badge badge-green"></b></h3></div>
			<button class="btn btn-primary btn-sm" id="new-post">＋ 새 글 시작</button>
		</div>
		<div class="bar" style="margin:.7rem 0"><i id="loop-bar"></i></div>
		<div id="today" class="callout callout-green" style="margin-bottom:.8rem"></div>
		<div id="phases"></div>
		<div style="margin-top:.8rem;text-align:right"><button class="btn btn-ghost btn-sm" id="reset-all">전체 초기화</button></div>
	</div>
</StudioLayout>

<script>
	import { monthPlan } from '../data/keywords';
	import { stagePlan, type Profile } from '../data/onboarding';

	const $ = (id: string) => document.getElementById(id)!;
	const esc = (s: any) => String(s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' })[c] as string);

	// ── 프로필 / 히어로 ──
	let profile: Profile | null = null;
	try { profile = JSON.parse(localStorage.getItem('studio-profile-v1') || 'null'); } catch {}
	const hero = $('hero');
	if (!profile) {
		hero.innerHTML = `<div class="hero-card fade">
			<span class="eyebrow">1:1 맞춤 설정</span>
			<h1 class="page-h" style="margin:.5rem 0 .3rem">안녕하세요 👋 먼저 <span class="grad-text">나에게 맞게</span> 설정할까요?</h1>
			<p class="muted" style="margin:0 0 1rem">지금 단계에 맞춰 대시보드를 설계해 드려요.</p>
			<a class="btn btn-accent" href="/onboarding">시작 설정하기 →</a></div>`;
	} else {
		const sp = stagePlan(profile);
		const hi = profile.name ? `${esc(profile.name)}님,` : '안녕하세요,';
		hero.innerHTML = `<div class="hero-card fade">
			<span class="eyebrow">${esc(profile.goal)} · ${esc((profile.channels||[]).length)}개 채널${profile.niche ? ' · ' + esc(profile.niche) : ''}</span>
			<h1 class="page-h" style="margin:.5rem 0 .3rem">${hi} <span class="grad-text">${esc(sp.headline)}</span></h1>
			<p class="muted" style="margin:0 0 1rem">${esc(sp.focus)}</p>
			<div style="display:flex;gap:.5rem;flex-wrap:wrap">
				<a class="btn btn-accent" href="${sp.primaryCta.href}">${esc(sp.primaryCta.label)} →</a>
				<a class="btn btn-ghost" href="/onboarding">설정 변경</a>
			</div>
			<p style="color:var(--muted-2);margin:.8rem 0 0;font-size:.82rem">다음 목표 · ${esc(sp.nextMilestone)}</p></div>`;
	}

	// ── 발행 실적(파이프라인 '발행 완료' 기록) ──
	let pubs: any[] = [];
	try { pubs = JSON.parse(localStorage.getItem('studio-pubs-v1') || '[]'); } catch {}
	const week = pubs.filter((p) => (Date.now() - new Date(p.d).getTime()) / 86400000 <= 7).length;
	const gold = pubs.filter((p) => (p.tier || '').includes('💰💰💰')).length;
	$('pub-stats').innerHTML = `
		<div class="card" style="text-align:center"><div class="muted" style="font-size:.78rem">총 발행</div><b style="font-size:1.6rem" data-count="${pubs.length}">0</b><span style="font-size:.9rem">건</span></div>
		<div class="card" style="text-align:center;border-color:rgba(52,211,153,.3);background:var(--accent-soft)"><div class="muted" style="font-size:.78rem">최근 7일</div><b style="font-size:1.6rem;color:var(--accent)" data-count="${week}">0</b><span style="font-size:.9rem;color:var(--accent)">건</span></div>
		<div class="card" style="text-align:center"><div class="muted" style="font-size:.78rem">💰💰💰 고단가 글</div><b style="font-size:1.6rem" data-count="${gold}">0</b><span style="font-size:.9rem">건</span></div>`;
	// 숫자 카운트업 연출
	document.querySelectorAll<HTMLElement>('[data-count]').forEach((el) => {
		const target = Number(el.dataset.count || 0); const t0 = performance.now();
		const tick = (t: number) => { const p = Math.min(1, (t - t0) / 700); el.textContent = String(Math.round(target * (1 - Math.pow(1 - p, 3)))); if (p < 1) requestAnimationFrame(tick); };
		requestAnimationFrame(tick);
	});

	// ── 이번 달 시즌 키워드 ──
	const m = new Date().getMonth() + 1;
	const mp = monthPlan(m);
	$('month-tag').textContent = `(${m}월 · ${mp.theme})`;
	$('month-strategy').textContent = '💡 ' + mp.strategy;
	$('season-kws').innerHTML = mp.keywords
		.map(
			(k) => `<div class="card hover" style="padding:.6rem .85rem;display:flex;justify-content:space-between;align-items:center;gap:.6rem">
				<div><span class="tier">${k.tiers.join('')}</span> <b>${esc(k.kw)}</b>${k.note ? `<div class="muted" style="font-size:.76rem">${esc(k.note)}</div>` : ''}</div>
				<a class="btn btn-soft btn-sm" href="/pipeline?kw=${encodeURIComponent(k.kw)}">글쓰기 →</a>
			</div>`,
		)
		.join('');

	// ── 발행 루프 체크리스트 ──
	const GEN = '/tools/generate', APR = '/approval';
	const PHASES = [
		{ n: '0', kind: 'setup', title: '준비 — 채널·승인', goal: '수익 받을 그릇 먼저(최초 1회)', steps: [
			{ id: 's_goal', t: '운영 목표·채널 정하기', go: { l: '설정', h: '/onboarding' } },
			{ id: 's_open', t: '네이버 블로그 개설 + 실명인증', go: { l: '네이버', h: 'https://blog.naver.com', x: true } },
			{ id: 's_seed', t: '승인용 글 12~20개 채우기', go: { l: '글 생성', h: GEN } },
			{ id: 's_apr', t: '애드포스트/애드센스 신청', go: { l: '승인 체크', h: APR } },
		] },
		{ n: '1', kind: 'daily', title: '오늘의 발행', goal: '돈 되는 글감으로 채널별 발행', steps: [
			{ id: 'd_kw', t: '이번 달/고CPC 키워드 고르기', go: { l: '키워드', h: '/keywords' } },
			{ id: 'd_gen', t: '채널별 글 + 이미지 생성', go: { l: '글 생성', h: GEN } },
			{ id: 'd_fix', t: '초안 다듬기(수치·사실 확인)' },
			{ id: 'd_pub', t: '네이버/블로거에 붙여넣고 발행', go: { l: '네이버', h: 'https://blog.naver.com', x: true } },
		] },
		{ n: '2', kind: 'weekly', title: '주간 점검', goal: '뭐가 돈 되는지 확인', steps: [
			{ id: 'w_stat', t: '방문자·유입 키워드 확인' },
			{ id: 'w_next', t: '성과글 → 후속글 주제 메모' },
		] },
	];
	const KINDS: any = { setup: '최초 1회', daily: '매일', weekly: '주간' };
	const DAILY = PHASES.filter((p) => p.kind === 'daily').flatMap((p) => p.steps.map((s) => s.id));
	const KEY = 'studio-dash-v1';
	let done = new Set<string>();
	try { done = new Set(JSON.parse(localStorage.getItem(KEY) || '[]')); } catch {}
	const save = () => localStorage.setItem(KEY, JSON.stringify([...done]));

	function render() {
		let lk = '';
		$('phases').innerHTML = PHASES.map((p) => {
			const ck = p.steps.filter((s) => done.has(s.id)).length;
			const head = lk !== p.kind ? `<div class="muted" style="font-size:.72rem;font-weight:700;letter-spacing:.04em;margin:1rem 0 .4rem;text-transform:uppercase">${KINDS[p.kind]}</div>` : '';
			lk = p.kind;
			const steps = p.steps.map((s) => {
				const c = done.has(s.id);
				const go = (s as any).go ? `<a class="btn btn-soft btn-sm" href="${(s as any).go.h}" ${(s as any).go.x ? 'target="_blank" rel="noopener"' : ''}>${(s as any).go.l}${(s as any).go.x ? ' ↗' : ''}</a>` : '';
				return `<label style="display:flex;align-items:center;gap:.6rem;padding:.5rem .2rem;border-bottom:1px solid var(--line)">
					<input type="checkbox" data-id="${s.id}" ${c ? 'checked' : ''} style="width:18px;height:18px;accent-color:var(--accent)">
					<span style="flex:1;font-size:.92rem;${c ? 'color:#9aa0a8;text-decoration:line-through' : ''}">${esc(s.t)}</span>${go}</label>`;
			}).join('');
			return `${head}<div class="card" style="box-shadow:none;padding:.7rem .9rem"><div style="display:flex;justify-content:space-between;align-items:center"><b>${p.n}. ${esc(p.title)}</b><span class="muted" style="font-size:.78rem">${ck}/${p.steps.length}</span></div><div class="muted" style="font-size:.8rem;margin:.1rem 0 .3rem">${esc(p.goal)}</div>${steps}</div>`;
		}).join('');
		const ld = DAILY.filter((id) => done.has(id)).length;
		const pct = Math.round((ld / DAILY.length) * 100);
		($('loop-bar') as HTMLElement).style.width = pct + '%';
		$('loop-pct').textContent = pct + '%';
		// 오늘 할 일
		const setupLeft = PHASES.find((p) => p.kind === 'setup')!.steps.find((s) => !done.has(s.id));
		const next = (profile && (profile.stage === 'approved' || profile.stage === 'running')) ? PHASES.find((p) => p.kind === 'daily')!.steps.find((s) => !done.has(s.id)) : (setupLeft || PHASES.flatMap((p) => p.steps).find((s) => !done.has(s.id)));
		$('today').innerHTML = next ? `<b>오늘 할 일</b> · ${esc((next as any).t)}` : '🎉 오늘 발행 루프 완료! ‘＋ 새 글 시작’으로 다음 글을.';
	}
	$('phases').addEventListener('change', (e) => {
		const t = e.target as HTMLInputElement;
		if (t.matches('input[type=checkbox]')) { t.checked ? done.add(t.dataset.id!) : done.delete(t.dataset.id!); save(); render(); }
	});
	$('new-post').addEventListener('click', () => { DAILY.forEach((id) => done.delete(id)); save(); render(); window.scrollTo({ top: 0, behavior: 'smooth' }); });
	$('reset-all').addEventListener('click', () => { if (confirm('진행 상태를 모두 초기화할까요?')) { done = new Set(); save(); render(); } });
	render();
</script>
