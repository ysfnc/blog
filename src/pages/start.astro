---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title="실행 대시보드 — 오늘의 발행" description="매일 순서대로 진행하는 멀티채널 발행 실행 대시보드" />
		<style is:global>
			:root{
				--ink:#15161a; --muted:#6b6f76; --line:#e9e9ee; --bg:#f6f7f9; --card:#fff;
				--accent:#0a7c4a; --accent-soft:#e7f4ec; --amber:#b5780b; --amber-soft:#fbf2dd;
				--gray-soft:#eef0f3; --risk:#b23b3b; --shadow:0 1px 2px rgba(20,22,26,.04),0 6px 24px rgba(20,22,26,.05);
			}
			main{max-width:820px;margin:0 auto;padding:8px 18px 80px}
			h1{font-size:1.7rem;margin:.4rem 0 .2rem;letter-spacing:-.02em}
			.lead{color:var(--muted);margin:0 0 1rem;font-size:.95rem}

			.bar-wrap{position:sticky;top:0;z-index:5;background:var(--bg);padding:.6rem 0 .8rem;margin-bottom:.4rem}
			.bar{height:10px;background:var(--gray-soft);border-radius:999px;overflow:hidden}
			.bar > i{display:block;height:100%;width:0;background:var(--accent);border-radius:999px;transition:width .3s}
			.bar-meta{display:flex;justify-content:space-between;align-items:center;margin-top:.5rem;font-size:.85rem;color:var(--muted)}
			.bar-meta b{color:var(--ink)}
			.btn{cursor:pointer;border:1px solid var(--line);background:#fff;border-radius:8px;padding:.45rem .8rem;font-size:.82rem;font-weight:600;color:#333}
			.btn:hover{background:#f3f3f5}
			.btn.dark{background:var(--ink);color:#fff;border-color:var(--ink)}

			.today{background:var(--ink);color:#fff;border-radius:16px;padding:1rem 1.2rem;margin:.4rem 0 1.2rem;box-shadow:var(--shadow)}
			.today .lbl{font-size:.72rem;font-weight:700;letter-spacing:.06em;color:#9fe7c1}
			.today .txt{font-size:1.15rem;font-weight:700;margin:.25rem 0 .1rem;line-height:1.3}
			.today .ph{font-size:.78rem;color:#b9bcc3}
			.today .act{margin-top:.8rem;display:flex;gap:.5rem;flex-wrap:wrap}
			.today .act a, .today .act button{cursor:pointer;border:0;border-radius:8px;padding:.5rem .9rem;font-size:.85rem;font-weight:700;text-decoration:none;display:inline-block}
			.today .go{background:#15c074;color:#06301d}
			.today .check{background:#2a2c33;color:#fff}
			.today.alldone{background:var(--accent-soft);color:var(--accent)}
			.today.alldone .lbl{color:var(--accent)} .today.alldone .ph{color:#3a8a63}

			.kind{display:flex;align-items:center;gap:.5rem;margin:1.4rem 0 .5rem;font-size:.78rem;font-weight:700;letter-spacing:.04em;color:var(--muted);text-transform:uppercase}
			.kind::after{content:"";flex:1;height:1px;background:var(--line)}

			.phase{background:var(--card);border:1px solid var(--line);border-radius:14px;margin:0 0 .7rem;box-shadow:var(--shadow);overflow:hidden}
			.phead{display:flex;align-items:center;gap:.7rem;padding:.85rem 1rem;cursor:pointer;user-select:none}
			.pnum{width:30px;height:30px;border-radius:50%;background:var(--ink);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.85rem;flex:0 0 auto}
			.phase.done .pnum{background:var(--accent)}
			.ptitle{font-weight:700;font-size:1rem;flex:1;letter-spacing:-.01em}
			.pcount{font-size:.78rem;color:var(--muted);font-variant-numeric:tabular-nums}
			.chev{color:#bbb;transition:transform .2s;font-size:.8rem}
			.phase.collapsed .chev{transform:rotate(-90deg)}
			.phase.collapsed .steps{display:none}
			.goal{padding:0 1rem .4rem 3.4rem;margin:-.3rem 0 .2rem;font-size:.82rem;color:var(--muted)}
			.steps{padding:.2rem .9rem 1rem 1rem;display:grid;gap:.35rem}
			.step{display:flex;align-items:flex-start;gap:.6rem;padding:.5rem .6rem;border-radius:10px}
			.step:hover{background:#fafafb}
			.step input{margin-top:.2rem;width:18px;height:18px;flex:0 0 auto;cursor:pointer;accent-color:var(--accent)}
			.step .body{flex:1;min-width:0}
			.step .t{font-size:.92rem;color:#23262c}
			.step.checked .t{color:#9aa0a8;text-decoration:line-through}
			.step .note{font-size:.76rem;color:#9aa0a8;margin-top:.1rem}
			.step .do{display:inline-block;margin-top:.35rem;font-size:.78rem;font-weight:700;color:var(--accent);text-decoration:none;border:1px solid var(--accent-soft);background:var(--accent-soft);padding:.25rem .6rem;border-radius:7px}
			.step .do.ext::after{content:" ↗";color:#7bbf9c}
			.soon{font-size:.7rem;background:var(--gray-soft);color:#7a7f87;border-radius:5px;padding:.05rem .4rem;margin-left:.3rem}
			.foot{margin-top:1.6rem;font-size:.8rem;color:var(--muted);text-align:center}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>🚀 오늘의 발행 대시보드</h1>
			<p class="lead">위에서부터 순서대로 체크하며 진행하세요. 진행 상태는 이 브라우저에 자동 저장됩니다.</p>

			<div class="bar-wrap">
				<div class="bar"><i id="barFill"></i></div>
				<div class="bar-meta">
					<span>오늘의 발행 루프 <b id="loopPct">0%</b> <span id="loopCount" style="color:#aaa"></span></span>
					<button class="btn dark" id="newPost">＋ 새 글 시작</button>
				</div>
			</div>

			<div class="today" id="todayCard"></div>

			<div id="board"></div>

			<div class="foot">
				<button class="btn" id="resetAll">전체 초기화</button>
				<p style="margin-top:.8rem">최초 1회 설정 → 매일 ‘발행 루프’ 반복 → 주간 점검. 안전 노선(자사 채널·반자동)으로 진행합니다.</p>
			</div>
		</main>
		<Footer />

		<script>
			type Step = { id: string; t: string; note?: string; do?: { label: string; href: string; ext?: boolean }; soon?: boolean };
			type Phase = { n: string; title: string; goal: string; kind: 'setup' | 'daily' | 'weekly' | 'grow'; steps: Step[] };

			const GEN = '/tools/generate';
			const PHASES: Phase[] = [
				{
					n: '0', kind: 'setup', title: '준비 — 채널 개설 · 광고 승인',
					goal: '수익을 받을 ‘그릇’을 먼저 만든다. (최초 1회)',
					steps: [
						{ id: 's0_goal', t: '운영 목표 정하기 — 광고수익 / 제품홍보 / 둘 다' },
						{ id: 's0_naver', t: '네이버 블로그 개설 + 실명인증', note: '애드포스트는 실명계정만 수익화돼요', do: { label: '네이버 블로그', href: 'https://blog.naver.com', ext: true } },
						{ id: 's0_seed', t: '승인용 글 12~20개 채우기 (4시간 간격 예약)', do: { label: '글 생성하기', href: GEN } },
						{ id: 's0_adpost', t: '운영 30일 채운 뒤 애드포스트 신청', do: { label: '애드포스트', href: 'https://adpost.naver.com', ext: true } },
						{ id: 's0_blogger', t: '(병행) 블로그스팟 개설 + 필수 4페이지', do: { label: 'Blogger', href: 'https://www.blogger.com', ext: true } },
					],
				},
				{
					n: '1', kind: 'daily', title: '키워드 — 오늘 쓸 ‘돈 되는 글감’ 고르기',
					goal: '쓰고 싶은 글이 아니라 고단가 키워드를 고른다.',
					steps: [
						{ id: 'd1_topic', t: '오늘의 주제 한 줄 정하기 (예: 자동차보험, 근로장려금)' },
						{ id: 'd1_kw', t: '생성기로 고CPC 키워드 + 제목 + 본문 한 번에 뽑기', do: { label: '글 생성하기', href: GEN } },
						{ id: 'd1_pick', t: '추천 키워드 중 1개 골라 핵심 키워드 확정' },
					],
				},
				{
					n: '2', kind: 'daily', title: '본문 — 채널별 글 받기 · 다듬기',
					goal: '제목만 고르면 네이버·블로거 본문이 복붙 직전 상태로.',
					steps: [
						{ id: 'd2_gen', t: '네이버용 · 블로거용 본문 2종 생성 (이미 위에서 같이 나옴)', do: { label: '생성기 열기', href: GEN } },
						{ id: 'd2_fix', t: '초안 다듬기 — 수치·사실 1회 확인 (특히 보험·대출·세금)' },
					],
				},
				{
					n: '3', kind: 'daily', title: '발행 — 내 채널에 붙여넣기',
					goal: '내 소유 채널에 반자동(복붙)으로 안전하게 발행.',
					steps: [
						{ id: 'd3_naver', t: '네이버 블로그에 본문 붙여넣고 발행 (소제목 볼드·사진 넣기)', do: { label: '네이버 글쓰기', href: 'https://blog.naver.com', ext: true } },
						{ id: 'd3_blogger', t: '블로그스팟에도 붙여넣고 발행', do: { label: 'Blogger 글쓰기', href: 'https://www.blogger.com', ext: true } },
						{ id: 'd3_thread', t: '(선택) 스레드·인스타 카드뉴스로 변환해 추가 노출', soon: true },
					],
				},
				{
					n: '4', kind: 'daily', title: '수익화 — 광고·링크 확인',
					goal: '글마다 광고·CTA가 잘 붙었는지.',
					steps: [
						{ id: 'd4_ads', t: '애드포스트/애드센스 광고 정상 노출 확인' },
						{ id: 'd4_cta', t: 'CTA 버튼·내부링크 1개 넣어 체류·순환 강화' },
					],
				},
				{
					n: '5', kind: 'weekly', title: '점검 — 무엇이 돈이 되는지 (주 1회)',
					goal: '성과 보고 다음 글 방향 잡기.',
					steps: [
						{ id: 'w5_stat', t: '방문자·유입 키워드 확인' },
						{ id: 'w5_next', t: '잘 된 글 → 연관 후속글 주제 메모' },
					],
				},
				{
					n: '6', kind: 'grow', title: '성장 — 채널 늘리기 (숙달 후)',
					goal: '반복이 손에 익으면 규정 한도 안에서 확장.',
					steps: [
						{ id: 'g6_scale', t: '채널/계정 늘리기 — 네이버 규정 한도 내에서만', note: '우회·다계정 공장은 계정 정지 위험 → 하지 않음' },
					],
				},
			];

			const KINDS: Record<string, string> = { setup: '최초 1회 설정', daily: '매일 — 발행 루프', weekly: '주간 점검', grow: '성장' };
			const KEY = 'nosim-dashboard-v1';
			const ALL_STEPS = PHASES.flatMap((p) => p.steps.map((s) => s.id));
			const DAILY_IDS = PHASES.filter((p) => p.kind === 'daily').flatMap((p) => p.steps.map((s) => s.id));

			let done: Set<string> = load();
			function load(): Set<string> { try { return new Set(JSON.parse(localStorage.getItem(KEY) || '[]')); } catch { return new Set(); } }
			function save() { localStorage.setItem(KEY, JSON.stringify([...done])); }

			const board = document.getElementById('board')!;
			const collapsed = new Set<string>();

			function render() {
				let lastKind = '';
				board.innerHTML = PHASES.map((p) => {
					const total = p.steps.length;
					const ck = p.steps.filter((s) => done.has(s.id)).length;
					const pdone = ck === total;
					const isCollapsed = collapsed.has(p.n) || (pdone && p.kind === 'setup');
					const head = (lastKind !== p.kind) ? `<div class="kind">${KINDS[p.kind]}</div>` : '';
					lastKind = p.kind;
					const steps = p.steps.map((s) => {
						const c = done.has(s.id);
						const act = s.do ? `<a class="do ${s.do.ext ? 'ext' : ''}" href="${s.do.href}" target="_blank" rel="noopener">${s.do.label}</a>` : '';
						const soon = s.soon ? '<span class="soon">곧 추가</span>' : '';
						const note = s.note ? `<div class="note">${s.note}</div>` : '';
						return `<label class="step ${c ? 'checked' : ''}"><input type="checkbox" data-id="${s.id}" ${c ? 'checked' : ''}><span class="body"><span class="t">${s.t}${soon}</span>${note}${act}</span></label>`;
					}).join('');
					return `${head}<div class="phase ${pdone ? 'done' : ''} ${isCollapsed ? 'collapsed' : ''}" data-ph="${p.n}">
						<div class="phead"><div class="pnum">${pdone ? '✓' : p.n}</div><div class="ptitle">${p.title}</div><div class="pcount">${ck}/${total}</div><div class="chev">▾</div></div>
						<div class="goal">${p.goal}</div>${`<div class="steps">${steps}</div>`}</div>`;
				}).join('');

				// 진행률 = 매일 루프 기준
				const ldone = DAILY_IDS.filter((id) => done.has(id)).length;
				const pct = Math.round((ldone / DAILY_IDS.length) * 100);
				(document.getElementById('barFill') as HTMLElement).style.width = pct + '%';
				document.getElementById('loopPct')!.textContent = pct + '%';
				document.getElementById('loopCount')!.textContent = `(${ldone}/${DAILY_IDS.length} 단계)`;
				renderToday();
			}

			function renderToday() {
				const card = document.getElementById('todayCard')!;
				// 우선순위: 설정 미완 → 그 단계, 아니면 매일 루프 다음 단계
				const setupLeft = PHASES.find((p) => p.kind === 'setup')!.steps.find((s) => !done.has(s.id));
				const next = setupLeft || PHASES.filter((p) => p.kind === 'daily').flatMap((p) => p.steps.map((s) => ({ s, p }))).find((x) => !done.has(x.s.id));
				if (!next) {
					card.className = 'today alldone';
					card.innerHTML = `<div class="lbl">오늘 할 일</div><div class="txt">🎉 오늘 발행 루프 완료!</div><div class="ph">‘＋ 새 글 시작’으로 다음 글을 이어가세요.</div>`;
					return;
				}
				const step: Step = (next as any).s ?? (next as Step);
				const ph = (next as any).p as Phase | undefined;
				const phName = ph ? `Phase ${ph.n} · ${ph.title}` : 'Phase 0 · 준비';
				const act = step.do ? `<a class="go" href="${step.do.href}" target="_blank" rel="noopener">${step.do.label} →</a>` : '';
				card.className = 'today';
				card.innerHTML = `<div class="lbl">오늘 할 일</div><div class="txt">${step.t}</div><div class="ph">${phName}</div><div class="act">${act}<button class="check" data-done="${step.id}">완료 체크</button></div>`;
			}

			board.addEventListener('change', (e) => {
				const t = e.target as HTMLInputElement;
				if (t.matches('input[type=checkbox]')) { toggle(t.dataset.id!, t.checked); }
			});
			board.addEventListener('click', (e) => {
				const head = (e.target as HTMLElement).closest('.phead');
				if (head) { const ph = head.parentElement!.dataset.ph!; collapsed.has(ph) ? collapsed.delete(ph) : collapsed.add(ph); render(); }
			});
			document.getElementById('todayCard')!.addEventListener('click', (e) => {
				const b = (e.target as HTMLElement).closest('[data-done]') as HTMLElement | null;
				if (b) toggle(b.dataset.done!, true);
			});
			function toggle(id: string, on: boolean) { on ? done.add(id) : done.delete(id); save(); render(); }

			document.getElementById('newPost')!.addEventListener('click', () => {
				DAILY_IDS.forEach((id) => done.delete(id));
				save(); collapsed.clear(); render();
				window.scrollTo({ top: 0, behavior: 'smooth' });
			});
			document.getElementById('resetAll')!.addEventListener('click', () => {
				if (confirm('모든 진행 상태(설정 포함)를 초기화할까요?')) { done = new Set(); save(); collapsed.clear(); render(); }
			});

			render();
		</script>
	</body>
</html>
