---
import StudioLayout from '../../layouts/StudioLayout.astro';
---

<StudioLayout title="글 생성기" active="generate">
	<h1 class="page-h">✍️ 채널별 글 생성기</h1>
	<p class="page-sub">주제어 → 고CPC 키워드 → <b>채널마다 맞춤</b> 글 + 썸네일·카드뉴스. 생성=Claude 구독, 발행 전 <b>안전 린터</b>가 위험을 잡아줍니다.</p>

	<div class="card">
		<div class="grid grid-2">
			<div class="field"><label>주제어 (필수)</label><input id="topic" type="text" placeholder="예: 자동차보험 비교, 연말정산 환급" autocomplete="off" /></div>
			<div class="field"><label>핵심 키워드 직접 지정 (선택)</label><input id="keyword" type="text" placeholder="비우면 추천만, 넣으면 그 키워드로" autocomplete="off" /></div>
		</div>
		<div style="display:flex;gap:.6rem;align-items:center;flex-wrap:wrap">
			<button id="go" class="btn btn-accent">① 키워드 조사하기</button>
			<span id="status" class="muted" style="font-size:.86rem"></span>
		</div>
		<p id="error" class="callout callout-red hidden" style="margin-top:.7rem"></p>
	</div>

	<div id="master" class="card hidden" style="margin-top:1rem">
		<div style="display:flex;justify-content:space-between;align-items:center"><h3 class="section-h" style="margin:0">🎯 추천 키워드 &amp; 핵심 재료</h3><span id="primary" class="badge badge-green"></span></div>
		<div id="keywords" style="margin:.6rem 0"></div>
		<b style="font-size:.85rem">핵심 포인트</b><ul id="points" style="margin:.3rem 0 0;padding-left:1.1rem;font-size:.88rem"></ul>
		<div style="margin-top:.5rem;font-size:.85rem"><b>관점</b> · <span id="angle"></span></div>
	</div>

	<div id="channelArea" class="hidden">
		<h3 class="section-h">② 채널별로 글 받기</h3>
		<div class="tabs" id="tabs"></div>
		<div id="panels"></div>
		<span id="cstatus" class="muted" style="font-size:.85rem"></span>
	</div>

	<p class="hint" style="margin-top:1rem">⚠️ AI 초안입니다. 발행 전 수치·사실 확인 + 안전 린터 경고를 꼭 보세요. 자사 채널·반자동(복붙) 노선.</p>
</StudioLayout>

<script>
	import { lintContent } from '../../data/guard';

	const CH = [
		{ id: 'naver', label: '네이버 블로그', color: '#03c75a' },
		{ id: 'blogspot', label: '블로그스팟', color: '#ee6c00' },
		{ id: 'threads', label: '스레드', color: '#111111' },
		{ id: 'instagram', label: '인스타 카드뉴스', color: '#c4239f' },
	];
	const $ = (id: string) => document.getElementById(id)!;
	const esc = (s: any) => String(s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' })[c] as string);
	let master: any = null;
	const data: any = {};
	const photos: any = {};
	let active = 'naver';

	// ?topic= prefill
	const qp = new URLSearchParams(location.search);
	if (qp.get('topic')) ($('topic') as HTMLInputElement).value = qp.get('topic')!;

	$('go').addEventListener('click', runMaster);
	async function runMaster() {
		const topic = ($('topic') as HTMLInputElement).value.trim(), keyword = ($('keyword') as HTMLInputElement).value.trim();
		if (!topic && !keyword) return err('주제어 또는 키워드를 입력해주세요.');
		$('error').classList.add('hidden');
		($('go') as HTMLButtonElement).disabled = true;
		$('status').innerHTML = '<span class="spin"></span> 키워드 조사 중…';
		try {
			const r = await fetch('/api/generate', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ mode: 'master', topic, keyword }) });
			const d = await r.json();
			if (d.shareMode) { $('status').textContent = ''; err('공유 버전에서는 원클릭 생성이 꺼져 있어요 → 런처에서 각자 Claude로 작성하세요: /tools/launch'); return; }
			if (!r.ok || d.error) throw new Error(d.error || '실패');
			master = d.master; renderMaster(); $('status').textContent = '완료 ✓ 아래에서 채널을 골라 글을 받으세요.';
		} catch (e: any) { err(e.message); $('status').textContent = ''; }
		finally { ($('go') as HTMLButtonElement).disabled = false; }
	}
	function err(m: string) { $('error').textContent = m; $('error').classList.remove('hidden'); }

	function renderMaster() {
		$('primary').textContent = '핵심: ' + master.primaryKeyword;
		$('keywords').innerHTML = master.recommendedKeywords.map((k: any) =>
			`<div style="display:flex;gap:.5rem;align-items:start;padding:.35rem 0;border-bottom:1px dashed var(--line);font-size:.9rem"><span class="tier">${esc(k.cpcTier)}</span><span><b>${esc(k.keyword)}</b> <span class="badge badge-cat">${esc(k.category)}</span><div class="muted" style="font-size:.76rem">${esc(k.reason)}</div></span></div>`).join('');
		$('points').innerHTML = master.keyPoints.map((p: any) => `<li>${esc(p)}</li>`).join('');
		$('angle').textContent = master.angle;
		$('master').classList.remove('hidden'); $('channelArea').classList.remove('hidden');
		renderTabs(); renderPanels(); selectTab(active);
	}
	function renderTabs() {
		$('tabs').innerHTML = CH.map((c) => `<button class="tab ${data[c.id] ? 'ready' : ''} ${c.id === active ? 'active' : ''}" data-tab="${c.id}"><span class="dot"></span>${c.label}</button>`).join('');
		$('tabs').querySelectorAll('.tab').forEach((b) => b.addEventListener('click', () => selectTab((b as HTMLElement).dataset.tab!)));
	}
	function renderPanels() { $('panels').innerHTML = CH.map((c) => `<div class="panel ${c.id === active ? '' : 'hidden'}" data-panel="${c.id}" id="panel_${c.id}"></div>`).join(''); CH.forEach((c) => paintPanel(c.id)); }
	function selectTab(id: string) { active = id; $('tabs').querySelectorAll('.tab').forEach((b) => b.classList.toggle('active', (b as HTMLElement).dataset.tab === id)); $('panels').querySelectorAll('.panel').forEach((p) => p.classList.toggle('hidden', (p as HTMLElement).dataset.panel !== id)); }

	function paintPanel(id: string) {
		const el = $('panel_' + id), c = CH.find((x) => x.id === id)!;
		if (!data[id]) { el.innerHTML = `<div class="card" style="text-align:center;padding:1.8rem"><p class="muted">아직 이 채널 글이 없어요.</p><button class="btn btn-accent" data-gen="${id}">${c.label} 맞춤 글 받기</button></div>`; el.querySelector('[data-gen]')!.addEventListener('click', () => runChannel(id)); return; }
		const r = data[id];
		const lint = lintContent(r.body);
		const lintHtml = lint.length ? `<div style="margin:.6rem 0">${lint.map((h) => `<div class="callout ${h.level === 'red' ? 'callout-red' : 'callout-gold'}" style="margin-bottom:.4rem;font-size:.82rem"><b>${h.level === 'red' ? '🔴 차단' : '🟡 주의'} · ${esc(h.rule)}</b> (${esc(h.matched)}) — ${esc(h.advice)}</div>`).join('')}</div>` : `<div class="callout callout-green" style="margin:.6rem 0;font-size:.82rem">✅ 안전 린터 통과 — 위험 표현 없음</div>`;
		const tags = (r.hashtags || []).length ? `<div style="display:flex;flex-wrap:wrap;gap:.3rem;margin:.5rem 0">${r.hashtags.map((t: any) => `<span class="chip">#${esc(t)}</span>`).join('')}</div><button class="btn btn-ghost btn-sm" data-copy="tags:${id}">해시태그 복사</button>` : '';
		el.innerHTML = `<div class="card">
			<div style="display:flex;justify-content:space-between;align-items:center"><h3 class="section-h" style="margin:0">${c.label}</h3><button class="btn btn-ghost btn-sm" data-gen="${id}">다시 받기</button></div>
			<div class="badge badge-green" style="margin:.3rem 0">🎯 ${esc(r.keywordFocus)}</div>
			<div style="font-weight:700;font-size:1.05rem;margin:.2rem 0 .4rem">${esc(r.title)}</div>
			${lintHtml}
			<div style="display:flex;justify-content:space-between;align-items:center"><b style="font-size:.85rem">본문</b><button class="btn btn-soft btn-sm" data-copy="body:${id}">본문 복사</button></div>
			<textarea id="body_${id}" spellcheck="false">${esc(r.body)}</textarea>
			${tags}
			<div id="img_${id}" style="margin-top:.9rem;padding-top:.9rem;border-top:1px solid var(--line)"></div>
		</div>`;
		el.querySelector('[data-gen]')!.addEventListener('click', () => runChannel(id));
		el.querySelectorAll('[data-copy]').forEach((b) => b.addEventListener('click', () => doCopy((b as HTMLElement).dataset.copy!)));
		paintImage(id);
	}

	async function runChannel(id: string) {
		if (!master) return;
		$('cstatus').innerHTML = `<span class="spin"></span> ${CH.find((c) => c.id === id)!.label} 맞춤 글 생성 중… (약 40초)`;
		try {
			const r = await fetch('/api/generate', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ mode: 'channel', channel: id, master }) });
			const d = await r.json();
			if (!r.ok || d.error) throw new Error(d.error || '실패');
			data[id] = d.result; renderTabs(); paintPanel(id); selectTab(id); $('cstatus').textContent = '완료 ✓';
		} catch (e: any) { $('cstatus').textContent = '오류: ' + e.message; }
	}
	function doCopy(key: string) { const [type, id] = key.split(':'); let text = ''; if (type === 'body') text = ($('body_' + id) as HTMLTextAreaElement).value; else if (type === 'tags') text = (data[id].hashtags || []).map((t: any) => '#' + t).join(' '); navigator.clipboard.writeText(text); }

	// ── 이미지 ──
	function paintImage(id: string) {
		const box = $('img_' + id), r = data[id];
		if (id === 'instagram') {
			box.innerHTML = `<h4 style="margin:0 0 .5rem">🖼️ 카드뉴스 (${r.cards.length}장)</h4><div id="cards_${id}" style="display:flex;gap:.6rem;overflow-x:auto;padding:.3rem 0"></div><div style="display:flex;gap:.4rem;flex-wrap:wrap;margin-top:.4rem"><button class="btn btn-ghost btn-sm" data-allcards="${id}">로컬 이미지 전체 저장</button><button class="btn btn-soft btn-sm" data-igmiri>🎨 미리캔버스로 (카드텍스트 복사)</button></div>`;
			const row = $('cards_' + id);
			r.cards.forEach((cd: any, i: number) => { const url = renderCard({ w: 1080, h: 1350, kicker: `${i + 1} / ${r.cards.length}`, headline: i === 0 ? r.thumbnail.headline : cd.heading, sub: i === 0 ? r.thumbnail.sub : cd.body, color: '#c4239f', theme: 'grad' }); const fig = document.createElement('figure'); fig.style.cssText = 'margin:0;flex:0 0 auto;width:150px'; fig.innerHTML = `<img src="${url}" style="width:150px;height:188px;object-fit:cover;border-radius:8px;border:1px solid var(--line)"><div style="text-align:center"><a href="${url}" download="insta_${i + 1}.png" style="font-size:.72rem">저장</a></div>`; row.appendChild(fig); });
			box.querySelector('[data-allcards]')!.addEventListener('click', () => r.cards.forEach((cd: any, i: number) => download(renderCard({ w: 1080, h: 1350, kicker: `${i + 1} / ${r.cards.length}`, headline: i === 0 ? r.thumbnail.headline : cd.heading, sub: i === 0 ? r.thumbnail.sub : cd.body, color: '#c4239f', theme: 'grad' }), `insta_${i + 1}.png`)));
			box.querySelector('[data-igmiri]')!.addEventListener('click', async () => { const txt = ['[표지] ' + r.thumbnail.headline + '\n' + r.thumbnail.sub, ...r.cards.map((cd: any, i: number) => `[카드 ${i + 1}] ${cd.heading}\n${cd.body}`)].join('\n\n'); await navigator.clipboard.writeText(txt); let miri: any = {}; try { miri = JSON.parse(localStorage.getItem('miri-templates-v1') || '{}'); } catch {} window.open(miri.instagram || 'https://www.miricanvas.com/v2/ko/design2', '_blank', 'noopener'); });
			return;
		}
		if (id === 'naver') {
			box.innerHTML = `<h4 style="margin:0 0 .5rem">📷 사진 — 내 사진 업로드</h4>${(r.photoSlots || []).length ? '<div>' + r.photoSlots.map((s: any) => `<div style="font-size:.83rem;padding:.2rem 0 .2rem 1.1rem">📷 ${esc(s)}</div>`).join('') + '</div>' : ''}<div id="drop_${id}" style="border:2px dashed var(--line-2);border-radius:10px;padding:1rem;text-align:center;color:var(--muted);font-size:.85rem;cursor:pointer;background:var(--paper)">사진을 끌어다 놓거나 클릭 (여러 장)</div><input type="file" accept="image/*" multiple class="hidden" id="file_${id}"><div id="ph_${id}" style="display:flex;gap:.5rem;flex-wrap:wrap;margin:.6rem 0"></div><button class="btn btn-soft btn-sm hidden" id="mkthumb_${id}">대표 사진에 제목 얹어 썸네일 만들기</button><div id="thumbout_${id}" style="margin-top:.6rem"></div>`;
			wirePhotos(id, r); return;
		}
		const w = id === 'blogspot' ? 1200 : 1080, h = id === 'blogspot' ? 630 : 1350;
		const url = renderCard({ w, h, kicker: id === 'blogspot' ? '블로그스팟 대표' : 'THREADS', headline: r.thumbnail.headline, sub: r.thumbnail.sub, color: CH.find((c) => c.id === id)!.color, theme: 'dark' });
		box.innerHTML = `<h4 style="margin:0 0 .5rem">🖼️ 썸네일 — 로컬 생성</h4><img src="${url}" style="max-width:100%;border-radius:10px;border:1px solid var(--line)"><div style="margin-top:.5rem"><a class="btn btn-soft btn-sm" href="${url}" download="${id}_thumb.png">썸네일 저장</a></div>`;
	}
	function wirePhotos(id: string, r: any) {
		const drop = $('drop_' + id), file = $('file_' + id) as HTMLInputElement, wrap = $('ph_' + id);
		photos[id] = photos[id] || [];
		drop.addEventListener('click', () => file.click());
		['dragover', 'dragleave', 'drop'].forEach((ev) => drop.addEventListener(ev, (e) => { e.preventDefault(); (drop as HTMLElement).style.borderColor = ev === 'dragover' ? 'var(--accent)' : 'var(--line-2)'; if (ev === 'drop') addFiles((e as DragEvent).dataTransfer!.files); }));
		file.addEventListener('change', () => addFiles(file.files!));
		function addFiles(list: FileList) { [...list].forEach((f) => { if (!f.type.startsWith('image/')) return; const rd = new FileReader(); rd.onload = () => { photos[id].push(rd.result); paint(); }; rd.readAsDataURL(f); }); }
		function paint() { wrap.innerHTML = photos[id].map((u: string, i: number) => `<figure style="margin:0;position:relative"><img src="${u}" style="width:90px;height:90px;object-fit:cover;border-radius:8px;border:1px solid var(--line)">${i === 0 ? '<span class="badge badge-green" style="position:absolute;top:3px;left:3px">대표</span>' : ''}</figure>`).join(''); $('mkthumb_' + id).classList.toggle('hidden', !photos[id].length); }
		$('mkthumb_' + id).addEventListener('click', () => { if (!photos[id].length) return; renderPhotoThumb(photos[id][0], r.thumbnail.headline, (url: string) => { $('thumbout_' + id).innerHTML = `<img src="${url}" style="max-width:100%;border-radius:10px;border:1px solid var(--line)"><div style="margin-top:.5rem"><a class="btn btn-soft btn-sm" href="${url}" download="naver_thumb.png">썸네일 저장</a></div>`; }); });
	}

	// ── Canvas ──
	function wrapText(ctx: any, text: string, maxW: number) { const lines: string[] = []; let line = ''; for (const ch of text) { if (ch === '\n') { lines.push(line); line = ''; continue; } if (ctx.measureText(line + ch).width > maxW && line) { lines.push(line); line = ch; } else line += ch; } if (line) lines.push(line); return lines; }
	function renderCard({ w, h, kicker, headline, sub, color, theme }: any) {
		const c = document.createElement('canvas'); c.width = w; c.height = h; const x = c.getContext('2d')!;
		if (theme === 'grad') { const g = x.createLinearGradient(0, 0, w, h); g.addColorStop(0, color); g.addColorStop(1, '#1c1030'); x.fillStyle = g; } else x.fillStyle = '#15161a';
		x.fillRect(0, 0, w, h); x.fillStyle = color; x.fillRect(0, 0, w * 0.018, h);
		const pad = w * 0.08, font = '"Apple SD Gothic Neo","Pretendard",-apple-system,sans-serif'; x.textBaseline = 'top';
		x.fillStyle = color; x.font = `700 ${Math.round(w * 0.032)}px ${font}`; x.fillText(kicker || '', pad, pad);
		x.fillStyle = '#fff'; x.font = `800 ${Math.round(w * 0.072)}px ${font}`; const lh = w * 0.088;
		let y = h * 0.3; wrapText(x, headline || '', w - pad * 2).slice(0, 6).forEach((l) => { x.fillText(l, pad, y); y += lh; });
		if (sub) { x.fillStyle = '#c9ccd2'; x.font = `500 ${Math.round(w * 0.036)}px ${font}`; y += lh * 0.3; wrapText(x, sub, w - pad * 2).slice(0, 5).forEach((l) => { x.fillText(l, pad, y); y += w * 0.05; }); }
		return c.toDataURL('image/png');
	}
	function renderPhotoThumb(dataURL: string, headline: string, cb: any) {
		const img = new Image(); img.onload = () => { const W = 1200, H = 630, c = document.createElement('canvas'); c.width = W; c.height = H; const x = c.getContext('2d')!; const r = Math.max(W / img.width, H / img.height), iw = img.width * r, ih = img.height * r; x.drawImage(img, (W - iw) / 2, (H - ih) / 2, iw, ih); const g = x.createLinearGradient(0, H * 0.3, 0, H); g.addColorStop(0, 'rgba(0,0,0,0)'); g.addColorStop(1, 'rgba(0,0,0,.78)'); x.fillStyle = g; x.fillRect(0, 0, W, H); const font = '"Apple SD Gothic Neo",-apple-system,sans-serif'; x.textBaseline = 'bottom'; x.fillStyle = '#fff'; x.font = `800 ${Math.round(W * 0.06)}px ${font}`; const pad = W * 0.06; let y = H - pad; wrapText(x, headline || '', W - pad * 2).slice(0, 3).reverse().forEach((l) => { x.fillText(l, pad, y); y -= W * 0.075; }); cb(c.toDataURL('image/png')); }; img.src = dataURL;
	}
	function download(url: string, name: string) { const a = document.createElement('a'); a.href = url; a.download = name; document.body.appendChild(a); a.click(); a.remove(); }
</script>
