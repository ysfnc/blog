---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title="채널 런처 — Claude로 바로 작성" description="키워드+짧은 메모만 넣고 채널을 고르면, 그 채널 기준이 세팅된 Claude로 이동" />
		<style is:global>
			:root{--ink:#15161a;--muted:#6b6f76;--line:#e9e9ee;--bg:#f6f7f9;--card:#fff;--accent:#0a7c4a;--accent-soft:#e7f4ec;--shadow:0 1px 2px rgba(20,22,26,.04),0 6px 24px rgba(20,22,26,.05)}
			main{max-width:820px;margin:0 auto;padding:1rem 1.1rem 80px}
			h1{font-size:1.6rem;margin:.3rem 0 .15rem;letter-spacing:-.02em}
			.sub{color:var(--muted);margin:0 0 1rem;font-size:.93rem}
			.card{border:1px solid var(--line);border-radius:14px;padding:1rem 1.1rem;margin:0 0 1rem;background:var(--card);box-shadow:var(--shadow)}
			label{display:block;font-weight:700;margin:.3rem 0 .25rem;font-size:.86rem}
			input[type=text]{width:100%;padding:.6rem .7rem;border:1px solid #ccc;border-radius:8px;font-size:1rem;box-sizing:border-box}
			.hint{color:#8a8f97;font-size:.78rem;margin:.25rem 0 0}
			.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(330px,1fr));gap:.8rem}
			.ch{border:1px solid var(--line);border-radius:14px;padding:1rem;background:#fff;box-shadow:var(--shadow)}
			.ch h3{margin:0 0 .2rem;font-size:1.05rem;display:flex;align-items:center;gap:.45rem}
			.ch p{margin:.1rem 0 .7rem;font-size:.82rem;color:var(--muted)}
			.btns{display:flex;gap:.5rem;flex-wrap:wrap}
			button,a.b{cursor:pointer;border:0;border-radius:8px;font-weight:700;text-decoration:none;display:inline-block;font-size:.86rem}
			.go{background:var(--ink);color:#fff;padding:.55rem 1rem}
			.cp{background:#f0f0f0;color:#222;padding:.55rem .9rem}
			.note{font-size:.84rem;color:#555;background:#f7f8fa;border:1px solid var(--line);border-radius:10px;padding:.8rem .9rem;margin-top:.4rem}
			.note code{background:#eceef1;padding:.05rem .35rem;border-radius:5px;font-size:.82rem}
			#err{color:#c0392b;font-weight:600;font-size:.85rem}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>🚀 채널 런처 — Claude로 바로 작성</h1>
			<p class="sub">키워드 + 짧은 메모만 넣고 채널을 고르면, <b>그 채널 기준(블로그 형식·수익화·자료 반영)이 세팅된 Claude 페이지</b>가 열립니다. 거기서 엔터만 치면 완성 글이 나와요. (구독 사용)</p>

			<div class="card">
				<label for="kw">키워드 (필수)</label>
				<input id="kw" type="text" placeholder="예: 자동차보험 비교견적" autocomplete="off" />
				<label for="memo" style="margin-top:.6rem">짧은 메모 (선택)</label>
				<input id="memo" type="text" placeholder="예: 갱신 앞두고 다이렉트로 30% 줄인 내 경험 위주로" autocomplete="off" />
				<label for="link" style="margin-top:.6rem">유입시킬 블로그 링크 (스레드/인스타용, 선택)</label>
				<input id="link" type="text" placeholder="https://blog.naver.com/..." autocomplete="off" />
				<p id="err" style="margin-top:.5rem"></p>
			</div>

			<div class="grid" id="grid"></div>

			<div class="note">
				💡 <b>Claude 데스크탑으로 쓰는 법</b> — 채널마다 <code>claude-channels/네이버.md</code> 같은 팩을 <b>프로젝트 ‘사용자 지정 지침’</b>으로 한 번만 등록해두면, 그 프로젝트에선 키워드만 적어도 그 채널 글이 나옵니다. (런처 ‘프롬프트 복사’ → 데스크탑에 붙여넣기도 가능)
			</div>
		</main>
		<Footer />

		<script>
			const CH = [
				{
					id: 'naver', emoji: '🟢', label: '네이버 블로그', desc: '구어체 후기 + 소제목 볼드 + 사진자리 + 해시태그 / 애드포스트',
					pack: `너는 네이버 블로그 전담 작가. 키워드+짧은 메모를 받아 네이버에 바로 올릴 완성 글을 써라.
규칙: 고CPC 글감(보험·대출·세금·정부지원 등)과 행동요구(신청/구매/조회 방법) 키워드 결합. 제목=질문/후기형(키워드 앞·숫자·궁금증). 본문=해요체, 소제목 **볼드**, 소제목 아래 "> 📷 [사진: 무엇]", 짧은 문단+줄바꿈, 1000자+. 다른 채널과 다른 표현(중복 회피).
수익화=네이버 애드포스트 자동광고(클릭유도·과장수익·약관위반 금지). 사실 날조 금지(모르면 '(확인 필요)'), 보험/대출/세금은 "정확한 내용은 공식 채널 확인 필요" 한 줄.
출력: ①제목 ②본문 ③해시태그 10개 ④대표 사진 위에 얹을 한 줄.`,
				},
				{
					id: 'blogspot', emoji: '🟠', label: '블로그스팟(구글)', desc: 'SEO H2/H3 정중체 + FAQ + 메타 / 애드센스',
					pack: `너는 블로그스팟(구글 Blogger) 전담 작가. 키워드+짧은 메모를 받아 구글에 바로 올릴 완성 글을 써라.
규칙: 고CPC 글감(보험·대출·세금·금융 등)과 행동요구 키워드 결합. 제목=SEO(키워드 앞·숫자·궁금증). 본문=정중체(~습니다), 결론 먼저, 마크다운 ## H2 / ### H3, 표·리스트, FAQ 1개, 1500자+, 핵심 키워드 반복. E-E-A-T 경험 한 줄.
수익화=구글 애드센스(+선택 쿠팡파트너스). 클릭유도·과장·약관위반 금지. 사실 날조 금지(모르면 '(확인 필요)'/'(출처: ___)'), YMYL 한 줄 고지.
출력: ①제목 ②본문(H2/H3·표·FAQ) ③메타설명 120~160자 ④히어로 썸네일 headline+sub.`,
				},
				{
					id: 'threads', emoji: '⚫', label: '스레드', desc: '짧은 멀티포스트 훅 + 블로그 유입 / 1장 이미지', needsLink: true,
					pack: `너는 스레드 전담 작가. 키워드+짧은 메모를 받아 스레드용 짧은 멀티포스트를 써라(목적=본 블로그 유입).
규칙: 트렌드/이슈 훅으로 시선 멈추게. 첫 포스트=한 줄 강한 훅. 본문=3~5개 짧은 포스트를 빈 줄로 구분(각 1~2문장, 1/n). 마지막 줄 "👉 자세히는 블로그에서: (링크)". 길지 않게. 해시태그 2~4개.
클릭유도·과장·약관위반 금지. 사실 날조 금지(모르면 '(확인 필요)').
출력: ①스레드 본문(빈 줄 구분 + 유입 링크 자리) ②해시태그 2~4 ③이미지 1장 문구 headline+sub.`,
				},
				{
					id: 'instagram', emoji: '🟣', label: '인스타 카드뉴스', desc: '카드 6~8장 + 캡션 + 해시태그 15~20',
					pack: `너는 인스타그램 카드뉴스 전담 작가. 키워드+짧은 메모를 받아 카드뉴스+캡션 완성본을 써라.
규칙: 고CPC 주제를 쉽게 풀어 저장·공유 유도, 본 블로그 유입. 표지=강한 한 줄. 카드 6~8장(각 제목+짧은 내용 2~3문장, 1장=표지/마지막=정리·CTA). 캡션=첫 줄 훅+줄바꿈+저장 CTA. 해시태그 15~20개.
클릭유도·과장·약관위반 금지. 사실 날조 금지(모르면 '(확인 필요)'), YMYL 한 줄 고지.
출력: ①카드뉴스 6~8장([카드 N] 제목/내용) ②캡션 ③해시태그 15~20 ④표지 썸네일 headline+sub.`,
				},
			];

			const $ = (id) => document.getElementById(id);
			function assemble(c) {
				const kw = $('kw').value.trim();
				const memo = $('memo').value.trim();
				const link = $('link').value.trim();
				let p = c.pack + `\n\n[키워드] ${kw}`;
				if (memo) p += `\n[메모] ${memo}`;
				if (c.needsLink && link) p += `\n[블로그 링크] ${link}`;
				p += `\n\n위 기준으로 이 채널에 바로 올릴 수 있게 작성해줘.`;
				return p;
			}
			function launch(c) {
				if (!$('kw').value.trim()) { $('err').textContent = '키워드를 입력해주세요.'; return; }
				$('err').textContent = '';
				window.open('https://claude.ai/new?q=' + encodeURIComponent(assemble(c)), '_blank', 'noopener');
			}
			async function copyPrompt(c, btn) {
				if (!$('kw').value.trim()) { $('err').textContent = '키워드를 입력해주세요.'; return; }
				$('err').textContent = '';
				await navigator.clipboard.writeText(assemble(c));
				const old = btn.textContent; btn.textContent = '복사됨 ✓'; setTimeout(() => (btn.textContent = old), 1200);
			}

			$('grid').innerHTML = CH.map(
				(c) => `<div class="ch"><h3>${c.emoji} ${c.label}</h3><p>${c.desc}</p><div class="btns"><button class="go" data-go="${c.id}">Claude에서 작성 →</button><button class="cp" data-cp="${c.id}">프롬프트 복사</button></div></div>`,
			).join('');
			$('grid').querySelectorAll('[data-go]').forEach((b) => b.addEventListener('click', () => launch(CH.find((c) => c.id === b.dataset.go))));
			$('grid').querySelectorAll('[data-cp]').forEach((b) => b.addEventListener('click', () => copyPrompt(CH.find((c) => c.id === b.dataset.cp), b)));
		</script>
	</body>
</html>
